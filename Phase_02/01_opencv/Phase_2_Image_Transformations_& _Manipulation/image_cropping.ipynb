   "source": [
    "import cv2\n",
    "\n",
    "image = cv2.imread('random.jpeg')\n",
    "\n",
    "if image is not None:\n",
    "    cropped = image[100:400, 200:500]\n",
    "    cv2.imshow('Original Image', image)\n",
    "    cv2.imshow('Cropped Image', cropped)\n",
    "    cv2.waitKey(0)\n",
    "    cv2.destroyAllWindows()"
   ]
  }
